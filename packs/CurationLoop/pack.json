{
  "id": "curation-loop",
  "version": "0.1.0",
  "kind": "capability-pack",
  "description": "Task-end curation queue and procedure candidate staging.",
  "dependencies": [
    "../ContextRecall",
    "../TheoryLoop"
  ],
  "targets": [
    {
      "from": "src/tools/procedure_candidates.py",
      "to": "~/.codex/tools/procedure_candidates.py"
    },
    {
      "from": "src/tools/curation_queue.py",
      "to": "~/.codex/tools/curation_queue.py"
    }
  ],
  "verify": [
    "\"{{PYTHON}}\" -m py_compile \"{{CODEX_HOME}}/tools/procedure_candidates.py\" \"{{CODEX_HOME}}/tools/curation_queue.py\"",
    "\"{{PYTHON}}\" \"{{CODEX_HOME}}/tools/curation_queue.py\" refresh",
    "\"{{PYTHON}}\" \"{{CODEX_HOME}}/tools/curation_queue.py\" list --json"
  ]
}
